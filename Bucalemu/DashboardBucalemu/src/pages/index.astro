---
const response = await fetch('http://api.jteanalytics.cl:3001/metrics/latest'); 
const data = await response.json();

const BucalemuBajoTemp = typeof data.ssr_bucalemu_bajo_temperatura === 'number' ? data.ssr_bucalemu_bajo_temperatura.toFixed(2) : 'N/A';
const BucalemuBajoNivel = typeof data.ssr_bucalemu_bajo_nivel === 'number' ? data.ssr_bucalemu_bajo_nivel.toFixed(2) : 'N/A';
const NilahueTemp = typeof data.ssr_nilahue_temperatura === 'number' ? data.ssr_nilahue_temperatura.toFixed(2) : 'N/A';
const NilahueNivel = typeof data.ssr_nilahue_nivel === 'number' ? data.ssr_nilahue_nivel.toFixed(2) : 'N/A';

const responseUpdate = await fetch('http://api.jteanalytics.cl:3001/metrics/update');
const dataUpdate = await responseUpdate.json();
const isoString = dataUpdate;
const lastUpdate = isoString
  ? new Date(isoString).toLocaleString('es-CL', {
      dateStyle: 'short',
      timeStyle: 'short',
      timeZone: 'America/Santiago'
    })
  : 'N/A';

---
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Bucalemu</title>
    <style>
      :root {
        --bg: #121212;
        --fg: #e0e0e0;
        --card: #1e1e1e;
        --accent: #444;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background-color: var(--bg);
        color: var(--fg);
        font-family: 'Segoe UI', sans-serif;
        padding: 2rem;
      }

      h1 {
        text-align: center;
        margin-bottom: 2rem;
        font-size: 2rem;
        color: var(--fg);
      }

      ul {
        max-width: 500px;
        margin: auto;
        padding: 1rem;
        list-style: none;
        background-color: var(--card);
        border-radius: 0.5rem;
        box-shadow: 0 0 10px rgba(255, 255, 255, 0.05);
      }

      li {
        padding: 1rem;
        border-bottom: 1px solid var(--accent);
      }

      li:last-child {
        border-bottom: none;
      }

      strong {
        color: #ccc;
      }
    </style>
  </head>
  <body>
    <br><br>
    <h1>SSR Bucalemu</h1>

    <ul>
      <li><strong>Última Actualización:</strong> <br>{lastUpdate} </li>
    </ul>

    <br><br>

    <ul>
      <li><strong>Nivel Bucalemu Bajo:</strong> {BucalemuBajoNivel} m</li>
      <li><strong>Temperatura Bucalemu Bajo:</strong> {BucalemuBajoTemp} °C</li>
    </ul>

    <br><br>

    <ul>
      <li><strong>Nivel Nilahue:</strong> {NilahueNivel} m</li>
      <li><strong>Temperatura Nilahue:</strong> {NilahueTemp} °C</li>
    </ul>
  </body>
</html>
